<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Product Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This information will appear on your branded photo"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp"/>

        <!-- Photo Thumbnail -->
        <ImageView
            android:id="@+id/ivPhotoThumb"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp"/>

        <!-- Artisan Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Name / Shop Name *"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="@color/white">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etArtisanName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Raju Chitragara"
                android:inputType="textPersonName"
                android:textSize="15sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Product Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product Name *"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="@color/white">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Channapatna Gombe"
                android:inputType="textCapWords"
                android:textSize="15sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Wood Type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wood Type"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupWood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipIvory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ivory Wood"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_selector"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRosewood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rosewood"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_selector"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTeak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teak"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_selector"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSandalwood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sandalwood"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_selector"/>
        </com.google.android.material.chip.ChipGroup>

        <!-- Price -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price (₹) *"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:startIconDrawable="@null"
            app:prefixText="₹  "
            app:boxBackgroundColor="@color/white">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 850"
                android:inputType="number"
                android:textSize="15sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── AI Description Section ──────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Product Description (Optional)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="6dp"/>

        <!-- Button to call Gemini -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerateAI"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="✨  Generate Description with AI"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@color/saffron"
            style="@style/Widget.MaterialComponents.Button"/>

        <!-- Loading indicator shown while Gemini is working -->
        <LinearLayout
            android:id="@+id/layoutAiLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">
            <ProgressBar
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="@color/saffron"
                android:layout_marginEnd="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generating description…"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Card that shows the AI-generated text -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAiDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/saffron_light"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Description"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/saffron"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tvAiDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/dark_text"
                    android:lineSpacingMultiplier="1.4"
                    android:text=""/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Generate Photo Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGeneratePhoto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✨  Generate Professional Photo"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:layout_marginBottom="32dp"
            app:backgroundTint="@color/karnataka_green"/>

    </LinearLayout>
</ScrollView>
