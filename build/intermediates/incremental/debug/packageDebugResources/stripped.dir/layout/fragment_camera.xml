<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <!-- Camera Viewfinder -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:implementationMode="compatible"
            app:scaleType="fillCenter"/>

        <!-- Guide Overlay -->
        <com.shilpakala.GuideOverlayView
            android:id="@+id/guideOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Guide text -->
        <TextView
            android:id="@+id/tvGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="Place product within the corners and tap capture"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp"
            android:background="#88000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

    </FrameLayout>

    <!-- Camera Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1C1C1C"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivCapturedThumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp"
            android:background="#333333"
            android:scaleType="centerCrop"
            android:visibility="invisible"/>

        <!-- Capture Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="📷  Capture Photo"
            android:textColor="@color/dark_text"
            android:textSize="15sp"
            app:backgroundTint="@color/white"
            app:cornerRadius="32dp"/>

        <!-- Next Button (hidden until photo taken) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Next →"
            android:textColor="@color/white"
            android:visibility="gone"
            app:backgroundTint="@color/karnataka_green"/>

    </LinearLayout>

</LinearLayout>
