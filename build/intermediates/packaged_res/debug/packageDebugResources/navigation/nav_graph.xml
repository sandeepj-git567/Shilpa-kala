<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.shilpakala.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_camera"
            app:destination="@id/cameraFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"/>
    </fragment>

    <fragment
        android:id="@+id/cameraFragment"
        android:name="com.shilpakala.CameraFragment"
        android:label="Camera"
        tools:layout="@layout/fragment_camera">
        <action
            android:id="@+id/action_camera_to_details"
            app:destination="@id/detailsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"/>
    </fragment>

    <fragment
        android:id="@+id/detailsFragment"
        android:name="com.shilpakala.DetailsFragment"
        android:label="Details"
        tools:layout="@layout/fragment_details">
        <argument
            android:name="photoPath"
            app:argType="string"
            android:defaultValue=""/>
        <action
            android:id="@+id/action_details_to_preview"
            app:destination="@id/previewFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"/>
    </fragment>

    <fragment
        android:id="@+id/previewFragment"
        android:name="com.shilpakala.PreviewFragment"
        android:label="Preview"
        tools:layout="@layout/fragment_preview">
        <argument android:name="photoPath"      app:argType="string" android:defaultValue=""/>
        <argument android:name="artisanName"   app:argType="string" android:defaultValue=""/>
        <argument android:name="productName"   app:argType="string" android:defaultValue=""/>
        <argument android:name="woodType"      app:argType="string" android:defaultValue="Ivory Wood"/>
        <argument android:name="price"         app:argType="string" android:defaultValue="0"/>
        <argument android:name="aiDescription" app:argType="string" android:defaultValue=""/>
        <action
            android:id="@+id/action_preview_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"/>
    </fragment>

</navigation>
